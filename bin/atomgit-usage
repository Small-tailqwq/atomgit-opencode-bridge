#!/usr/bin/env node
const https = require('https');
const fs = require('fs');
const path = require('path');

const AUTH_PATH = path.join(
  process.env.HOME || process.env.USERPROFILE || '/tmp',
  '.atomcode', 'auth.toml'
);
const STATUS_API = 'https://api.gitcode.com/api/v5/coding-plan/status-v2';
const REFRESH_URL = 'https://acs.atomgit.com/oauth/refresh';
const UA_STRING = 'atomcode/4.23.0';

function parseAuth(raw) {
  const get = (key) => {
    const m = raw.match(new RegExp('^' + key + '\\s*=\\s*"([^"]*)"', 'm'));
    return m ? m[1] : null;
  };
  const getNum = (key) => {
    const m = raw.match(new RegExp('^' + key + '\\s*=\\s*(-?\\d+)', 'm'));
    return m ? parseInt(m[1], 10) : null;
  };
  return {
    access_token: get('access_token'),
    refresh_token: get('refresh_token'),
    expires_in: getNum('expires_in'),
    created_at: getNum('created_at') || 0,
  };
}

function readAuth() {
  try { return parseAuth(fs.readFileSync(AUTH_PATH, 'utf8')); }
  catch { return null; }
}

function writeAuth(auth) {
  const content = [
    'access_token = "' + auth.access_token + '"',
    'refresh_token = "' + (auth.refresh_token || '') + '"',
    'token_type = "Bearer"',
    'expires_in = ' + auth.expires_in,
    'created_at = ' + auth.created_at,
  ].join('\n') + '\n';
  fs.writeFileSync(AUTH_PATH, content, { mode: 0o600 });
}

function isExpired(auth) {
  if (!auth.expires_in) return false;
  return Math.floor(Date.now() / 1000) >= auth.created_at + auth.expires_in - 300;
}

function httpsGet(url, token) {
  return new Promise((resolve, reject) => {
    const req = https.get(url, {
      headers: { Authorization: 'Bearer ' + token, 'User-Agent': UA_STRING },
      timeout: 10_000,
    }, (res) => {
      let body = '';
      res.on('data', c => body += c);
      res.on('end', () => {
        if (res.statusCode !== 200) return reject(new Error('HTTP ' + res.statusCode + ' ' + body));
        resolve(JSON.parse(body));
      });
    });
    req.on('error', reject);
    req.on('timeout', () => { req.destroy(); reject(new Error('timeout')); });
  });
}

function httpsPost(url, bodyJson) {
  return new Promise((resolve, reject) => {
    const body = JSON.stringify(bodyJson);
    const req = https.request(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(body),
        'User-Agent': UA_STRING,
      },
      timeout: 10_000,
    }, (res) => {
      let data = '';
      res.on('data', c => data += c);
      res.on('end', () => {
        if (res.statusCode !== 200) return reject(new Error('refresh failed: HTTP ' + res.statusCode));
        resolve(JSON.parse(data));
      });
    });
    req.on('error', reject);
    req.on('timeout', () => { req.destroy(); reject(new Error('timeout')); });
    req.end(body);
  });
}

async function ensureValidToken() {
  const auth = readAuth();
  if (!auth || !auth.access_token) throw new Error('未找到认证信息。请先运行: atomcode login');
  if (!isExpired(auth)) return auth.access_token;
  if (!auth.refresh_token) throw new Error('Token 已过期且无 refresh_token，请重新运行: atomcode login');
  const j = await httpsPost(REFRESH_URL, { refresh_token: auth.refresh_token });
  const now = Math.floor(Date.now() / 1000);
  const newAuth = {
    access_token: j.access_token,
    refresh_token: j.refresh_token || auth.refresh_token,
    expires_in: j.expires_in || auth.expires_in,
    created_at: now,
  };
  writeAuth(newAuth);
  return newAuth.access_token;
}

function bar(pct, width) {
  const filled = Math.round((pct / 100) * width);
  const empty = width - filled;
  return '█'.repeat(filled) + '░'.repeat(empty);
}

async function main() {
  const token = await ensureValidToken();
  const data = await httpsGet(STATUS_API, token);

  if (!data.current_usage) {
    console.log('未获取到用量信息');
    process.exit(1);
  }

  const u = data.current_usage;
  const pct = u.usage_percent || 0;
  const used = u.window_tokens_used || 0;
  const limit = u.window_token_limit || 0;
  const hours = u.window_hours || 0;
  const resetDisplay = u.reset_at_display || '';
  const secondsLeft = u.seconds_until_reset || 0;
  const desc = u.usage_status_desc || '';

  console.log('');
  console.log('  AtomGit CodingPlan 用量');
  console.log('  \u2501'.repeat(28));
  console.log('  调用次数:  ' + bar(pct, 20) + '  ' + pct.toFixed(0) + '%' + (limit ? ' (' + used + ' / ' + limit + ')' : ''));
  console.log('  窗口时长:    ' + hours + '小时滚动窗口');
  if (resetDisplay) console.log('  重置时间:    ' + resetDisplay + (secondsLeft ? ' (剩余 ' + secondsLeft + ' 秒)' : ''));
  if (desc) console.log('  状态描述:    ' + desc);
  if (data.window_quota_exhausted) console.log('  \u26A0\uFE0F  当前窗口配额已用完!');
  console.log('');

  if (data.codingplan_free) {
    const p = data.codingplan_free;
    console.log('  订阅: ' + (p.plan_name || 'CodingPlan') + ' \u00B7 剩余 ' + p.remaining_days + '/' + p.total_days + ' 天');
  }

  process.exit(0);
}

main().catch(e => {
  console.error('错误:', e.message);
  process.exit(1);
});
